{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pale Blue Dot",
  "version": "0.8.3",
  "identifier": "com.palebluedot.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Pale Blue Dot",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 600,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset: https://asset.localhost",
        "connect-src": "ipc: http://ipc.localhost https://ipc.localhost https://fonts.googleapis.com https://fonts.gstatic.com",
        "font-src": "'self' https://fonts.gstatic.com data:",
        "style-src": "'unsafe-inline' 'self' https://fonts.googleapis.com",
        "img-src": "'self' asset: http://asset.localhost https://asset.localhost blob: data: tauri:",
        "script-src": "'self' 'wasm-unsafe-eval'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "dmg": {
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 },
        "windowSize": { "width": 660, "height": 400 }
      }
    }
  }
}
