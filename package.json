{
  "name": "pale-blue-dot",
  "private": true,
  "version": "0.7.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "bench": "vitest run src/__tests__/performance --reporter=verbose",
    "bench:state": "vitest run rootcause1-state.bench --reporter=verbose",
    "bench:io": "vitest run rootcause2-io.bench --reporter=verbose",
    "bench:dom": "vitest run rootcause3-dom.bench --reporter=verbose",
    "bench:baseline": "vitest run src/__tests__/performance --reporter=verbose 2>&1 | tee benchmarks/baseline-$(date +%Y%m%d-%H%M%S).txt",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
