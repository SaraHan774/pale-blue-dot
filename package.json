    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^28.0.0",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@types/sharp": "^0.31.1",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^0.34.6",
    "eslint": "^8.56.0",
