{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "worker-report.v1",
  "title": "Worker Report v1",
  "description": "pbd-worker 가 task 완료 시 출력하는 보고서. pbd-work skill 이 이를 검증 후 Plans.md 의 cc:* 마커를 갱신.",
  "type": "object",
  "required": [
    "version",
    "task_id",
    "status",
    "files_changed",
    "validation_results",
    "self_review",
    "summary"
  ],
  "properties": {
    "version": {
      "const": "worker-report.v1"
    },
    "task_id": {
      "type": "string",
      "pattern": "^T[0-9A-Z_]+$",
      "description": "Plans.md 의 task ID (예: T7, T_DEMO)"
    },
    "status": {
      "enum": ["DONE", "PARTIAL", "FAILED"],
      "description": "DONE = DoD 만족 + validation 통과. PARTIAL = DoD 일부만. FAILED = 막힘"
    },
    "worktree_path": {
      "type": "string",
      "description": "이 worker 가 사용한 worktree 절대/상대 경로"
    },
    "branch": {
      "type": "string",
      "description": "git 브랜치 이름 (예: pbd/T7)"
    },
    "files_changed": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "change"],
        "properties": {
          "path": { "type": "string" },
          "change": { "enum": ["added", "modified", "deleted", "renamed"] },
          "reason": { "type": "string" }
        }
      }
    },
    "validation_results": {
      "type": "object",
      "required": ["lint", "build", "test"],
      "properties": {
        "lint": {
          "type": "object",
          "required": ["command", "result"],
          "properties": {
            "command": { "type": "string" },
            "result": { "enum": ["PASS", "FAIL", "SKIP"] },
            "duration_ms": { "type": "number" },
            "summary": { "type": "string" }
          }
        },
        "build": { "$ref": "#/properties/validation_results/properties/lint" },
        "test": { "$ref": "#/properties/validation_results/properties/lint" }
      }
    },
    "self_review": {
      "type": "object",
      "description": "5건 모두 응답 필수. 응답 누락 시 pbd-work 가 거부.",
      "required": ["dod_satisfied", "impact_covered", "mcp_type_sync", "tests_added", "regression_risk"],
      "properties": {
        "dod_satisfied": {
          "type": "object",
          "required": ["answer", "evidence"],
          "properties": {
            "answer": { "enum": ["yes", "no", "partial"] },
            "evidence": { "type": "string" }
          }
        },
        "impact_covered": {
          "type": "object",
          "required": ["answer", "callers"],
          "properties": {
            "answer": { "enum": ["yes", "no", "partial"] },
            "callers": { "type": "array", "items": { "type": "string" } }
          }
        },
        "mcp_type_sync": {
          "type": "object",
          "required": ["needed", "done"],
          "properties": {
            "needed": { "type": "boolean" },
            "done": { "type": "boolean" },
            "rebuild_command": { "type": "string" }
          }
        },
        "tests_added": {
          "type": "object",
          "required": ["answer"],
          "properties": {
            "answer": { "enum": ["added", "updated", "none"] },
            "test_files": { "type": "array", "items": { "type": "string" } },
            "skip_reason": { "type": "string" }
          }
        },
        "regression_risk": {
          "type": "object",
          "required": ["level", "areas"],
          "properties": {
            "level": { "enum": ["low", "medium", "high"] },
            "areas": { "type": "array", "items": { "type": "string" } }
          }
        }
      }
    },
    "out_of_scope_findings": {
      "type": "array",
      "description": "scope creep 으로 분류돼 다루지 않은 항목. 다음 task 후보.",
      "items": {
        "type": "object",
        "required": ["summary"],
        "properties": {
          "summary": { "type": "string" },
          "file": { "type": "string" },
          "suggested_task": { "type": "string" }
        }
      }
    },
    "summary": {
      "type": "string",
      "description": "사용자 / reviewer 가 빠르게 읽을 1-3 문장 요약"
    },
    "advisor_consults": {
      "type": "integer",
      "minimum": 0,
      "description": "이 task 에서 advisor 를 호출한 횟수"
    }
  },
  "additionalProperties": false
}
